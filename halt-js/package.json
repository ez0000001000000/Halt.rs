{
  "name": "halt-js",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client for Halt.rs - Multi-Agent Proxy for Swarm Control",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && rollup -c",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "multi-agent",
    "ai",
    "swarm",
    "circuit-breaker",
    "backpressure",
    "typescript",
    "javascript",
    "halt-rs"
  ],
  "author": "Halt.rs Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ez0000001000000/Halt.rs",
    "directory": "halt-js"
  },
  "bugs": {
    "url": "https://github.com/ez0000001000000/Halt.rs/issues"
  },
  "homepage": "https://github.com/ez0000001000000/Halt.rs#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
